# Copy to .env and fill in to enable LIVE data sources for the Python analytics.
# Everything defaults OFF — the site & script run on data/deliverables.csv.

# ---- Airtable ----
USE_AIRTABLE=0
AIRTABLE_API_KEY=pat_xxxxxxxxxxxxxxxx      # Personal Access Token
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE=Deliverables

# ---- Jira ----
USE_JIRA=0
JIRA_HOST=your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=xxxxxxxxxxxxxxxx
JIRA_JQL=project in (NWR, MHP, FLEET, VFO) ORDER BY updated DESC

# ---- Misc ----
TRACKER_TODAY=2026-07-22
